R-VERSION ?= 4.6.0

include ../common/init.mk
include $M/r.mk
ifeq ($(OS-NAME),windows)
# R CMD INSTALL needs a C toolchain to build the src/ shim; use the
# xpack gcc from the makes gcc.mk:
include $M/gcc.mk
R-TOOLCHAIN := $(GCC)
endif
include $(COMMON)/common.mk
include $(COMMON)/binding.mk

RLIB := .rlib
R-PROFILE-SITE := $(R-LOCAL)/lib/R/etc/Rprofile.site


#------------------------------------------------------------------------------
build:: build-doc

build-doc:: ReadMe.md

# Use R (not Rscript): the relocated Rscript binary has the build
# prefix compiled in and cannot find its R home. Avoid --vanilla,
# which would skip the Rprofile.site relocation shim from r.mk:
R-RUN := R --no-save --no-restore --no-init-file --no-echo

test:: $(LIBYAMLSTAR-SO-VERSION) $(R-PROFILE-SITE) $(R-TOOLCHAIN)
	mkdir -p $(RLIB)
	R_LIBS="$(RLIB)" $(R-RUN) -f tests/install-deps.R
	R CMD INSTALL --library=$(RLIB) .
	R_LIBS="$(RLIB)" $(R-RUN) -f tests/test-yamlstar.R

release-deps:: $(R)

clean::
	$(RM) -r $(RLIB) src/*.o src/*.so

$(R-PROFILE-SITE): $(R)
	printf '%s\n' \
	  '# Generated by r/Makefile for the relocated R installation.' \
	  'local({' \
	  '  wp <- file.path(R.home(), "tools", "which")' \
	  '  if (!file.exists(wp)) wp <- "which"' \
	  '  sw <- function(names) {' \
	  '    res <- character(length(names))' \
	  '    names(res) <- names' \
	  '    for (i in seq_along(names)) {' \
	  '      test <- tryCatch(' \
	  '        suppressWarnings(system(' \
	  '          paste(shQuote(wp), shQuote(names[i])),' \
	  '          intern = TRUE, ignore.stderr = TRUE)),' \
	  '        error = function(e) character())' \
	  '      res[i] <- if (length(test)) test[1] else ""' \
	  '    }' \
	  '    res' \
	  '  }' \
	  '  base::unlockBinding("Sys.which", baseenv())' \
	  '  assign("Sys.which", sw, envir = baseenv())' \
	  '  base::lockBinding("Sys.which", baseenv())' \
	  '})' \
	  > $@
