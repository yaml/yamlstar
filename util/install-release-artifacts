#!/usr/bin/env bash

set -euo pipefail

artifact_dir=${1:-.}
version=$(sed -n 's/^version: //p' Meta)

case "$(uname -s)" in
  Linux*) os=linux ;;
  Darwin*) os=macos ;;
  MINGW*|MSYS*|CYGWIN*) os=windows ;;
  *) os=unknown ;;
esac

case "$(uname -m)" in
  x86_64|amd64) arch=x64 ;;
  aarch64|arm64) arch=arm64 ;;
  *) arch=unknown ;;
esac

if [[ $os == linux && $arch == arm64 ]]; then
  arch=aarch64
fi

platform=$os-$arch

find_artifact() {
  local pattern=$1

  find "$artifact_dir" -maxdepth 2 -type f -name "$pattern" |
    LC_ALL=C sort |
    head -n1
}

cli_tar=$(
  find_artifact "yamlstar-$version-$platform.tar.xz"
)

cli_zip=$(
  find_artifact "yamlstar-$version-$platform.zip"
)

lib_tar=$(
  find_artifact "libyamlstar-$version-$platform.tar.xz"
)

lib_zip=$(
  find_artifact "libyamlstar-$version-$platform.zip"
)

if [[ -z "$cli_tar" && -z "$cli_zip" ]]; then
  cli_tar=$(find_artifact "yamlstar-$version-*.tar.xz")
  cli_zip=$(find_artifact "yamlstar-$version-*.zip")
fi

if [[ -z "$lib_tar" && -z "$lib_zip" ]]; then
  lib_tar=$(find_artifact "libyamlstar-$version-*.tar.xz")
  lib_zip=$(find_artifact "libyamlstar-$version-*.zip")
fi

if [[ -z "$lib_tar" && -z "$lib_zip" ]]; then
  echo "ERROR: No libyamlstar release artifact found in $artifact_dir" >&2
  exit 1
fi

if [[ -z "$cli_tar" && -z "$cli_zip" ]]; then
  echo "ERROR: No yamlstar CLI release artifact found in $artifact_dir" >&2
  exit 1
fi

work_dir=$(mktemp -d)
trap 'rm -rf "$work_dir"' EXIT

if [[ $cli_tar ]]; then
  tar -C "$work_dir" -xf "$cli_tar"
else
  unzip -q "$cli_zip" -d "$work_dir"
fi

if [[ $lib_tar ]]; then
  tar -C "$work_dir" -xf "$lib_tar"
else
  unzip -q "$lib_zip" -d "$work_dir"
fi

lib_dir=$(
  find "$work_dir" -mindepth 1 -maxdepth 1 -type d \
    -name "libyamlstar-$version-*" |
    LC_ALL=C sort |
  head -n1
)

cli_dir=$(
  find "$work_dir" -mindepth 1 -maxdepth 1 -type d \
    -name "yamlstar-$version-*" |
    LC_ALL=C sort |
    head -n1
)

if [[ -z "$lib_dir" ]]; then
  echo "ERROR: No unpacked libyamlstar release directory found" >&2
  exit 1
fi

if [[ -z "$cli_dir" ]]; then
  echo "ERROR: No unpacked yamlstar CLI release directory found" >&2
  exit 1
fi

mkdir -p cli/bin
rm -f cli/bin/yaml cli/bin/yaml.exe
if [[ -f "$cli_dir/yaml.exe" ]]; then
  cp -pP "$cli_dir"/yaml.exe cli/bin/
  chmod 755 cli/bin/yaml.exe
else
  cp -pP "$cli_dir"/yaml cli/bin/
  chmod 755 cli/bin/yaml
fi

mkdir -p libyamlstar/lib
rm -f libyamlstar/lib/libyamlstar.*
cp -pP "$lib_dir"/libyamlstar.* libyamlstar/lib/
cp -pP "$lib_dir"/*.h libyamlstar/lib/
if [[ -f libyamlstar/lib/libyamlstar.dll ]]; then
  cp -pP libyamlstar/lib/libyamlstar.dll \
    "libyamlstar/lib/libyamlstar.dll.$version"
fi
find cli/bin libyamlstar/lib -type f -exec touch {} +

echo "Installed release artifacts:"
ls -lh cli/bin/yaml*
ls -lh libyamlstar/lib/libyamlstar*
